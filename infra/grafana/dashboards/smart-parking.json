{
  "id": null,
  "uid": "smart-parking-overview",
  "title": "Smart Parking Overview",
  "tags": ["smart-parking"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [
        { "expr": "up{job=\"api-gateway\"}", "legendFormat": "api-gateway", "refId": "A" },
        { "expr": "up{job=\"user-service\"}", "legendFormat": "user-service", "refId": "B" },
        { "expr": "up{job=\"sensor-simulator\"}", "legendFormat": "sensor-simulator", "refId": "C" },
        { "expr": "up{job=\"spot-detection-service\"}", "legendFormat": "spot-detection", "refId": "D" },
        { "expr": "up{job=\"availability-service\"}", "legendFormat": "availability", "refId": "E" },
        { "expr": "up{job=\"reservation-service\"}", "legendFormat": "reservation", "refId": "F" },
        { "expr": "up{job=\"payment-service\"}", "legendFormat": "payment", "refId": "G" },
        { "expr": "up{job=\"penalty-service\"}", "legendFormat": "penalty", "refId": "H" },
        { "expr": "up{job=\"notification-service\"}", "legendFormat": "notification", "refId": "I" },
        { "expr": "up{job=\"analytics-service\"}", "legendFormat": "analytics", "refId": "J" }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (req/s) by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "HTTP 5xx Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "P99 HTTP Latency (ms) by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (application, le) (rate(http_server_requests_seconds_bucket[5m]))) * 1000",
          "legendFormat": "{{application}} p99",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "JVM Heap Used (MB) by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"}) / 1048576",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "Kafka Consumer Lag by Group",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum by (application) (kafka_consumer_fetch_manager_records_lag)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 7,
      "title": "DB Connection Pool — Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=~\".+-service\"}",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 8,
      "title": "Reservation Events Created (rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"reservation-service\", uri=\"/reservations\", method=\"POST\", status=\"201\"}[5m]))",
          "legendFormat": "new reservations/s",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 9,
      "title": "GC Pause Time (P99, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (application, le) (rate(jvm_gc_pause_seconds_bucket[5m]))) * 1000",
          "legendFormat": "{{application}} GC p99",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 10,
      "title": "Process Uptime (hours)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        { "expr": "process_uptime_seconds{job=\"api-gateway\"} / 3600", "legendFormat": "api-gateway", "refId": "A" },
        { "expr": "process_uptime_seconds{job=\"reservation-service\"} / 3600", "legendFormat": "reservation", "refId": "B" },
        { "expr": "process_uptime_seconds{job=\"payment-service\"} / 3600", "legendFormat": "payment", "refId": "C" },
        { "expr": "process_uptime_seconds{job=\"penalty-service\"} / 3600", "legendFormat": "penalty", "refId": "D" }
      ],
      "datasource": "Prometheus"
    }
  ]
}
